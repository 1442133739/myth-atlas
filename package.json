{
  "name": "myth-atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "start": "node src/server.js",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0",
    "topojson-client": "^3.1.0",
    "tsx": "^4.19.2",
    "vite": "^7.0.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/three": "^0.184.1",
    "@types/topojson-client": "^3.1.5",
    "playwright": "^1.60.0",
    "typescript": "^5.7.2"
  }
}
